{
  "mcpServers": {
    "gitgod": {
      "command": "npx",
      "args": ["tsx", "src/cli.ts", "serve"],
      "env": {
        "GITGOD_DATA_DIR": "./data"
      }
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer YOUR_GITHUB_PAT"
      }
    }
  }
}
