# GitGod LLM (OpenRouter). Copy to `.env` and set your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=xiaomi/mimo-v2-pro

# Firecrawl (Stage 2 enrich, non-GitHub URLs). Keys look like fc-... https://firecrawl.dev
FIRECRAWL_API_KEY=fc-71c4a38574c343d589ee45c29007aaa4

# Exa (MCP tools: exa_search, exa_contents, exa_answer). https://exa.ai
# EXA_API_KEY=

# Optional: after `gitgod enrich` (or `gitgod vault-sync`), copy docs/architecture into this vault
# GITGOD_OBSIDIAN_VAULT=~/Documents/vanta-brain

# Optional: Classifier-Ω (LLM) during enrich — loads docs/prompts/CLASSIFIER-OMEGA-SYSTEM.md; requires an LLM key from llm.ts
# GITGOD_CLASSIFIER_OMEGA=1
# GITGOD_CLASSIFIER_OMEGA_PROMPT=/absolute/path/to/custom-CLASSIFIER-OMEGA-SYSTEM.md

# --- GitHub star / topic-list poller (scripts/poll-github-starred.ts, scripts/starred-poll-cron.sh) ---
# GITHUB_TOKEN=ghp_...                    # required for the poller
# STARWEBHOOK_URL=https://...             # Hermes (or any) HTTPS endpoint — JSON POST on new star + list add/remove
# STARWEBHOOK_SECRET=                     # optional Bearer token for Authorization header
# STARWEBHOOK_ROUTING_AGENT=metatron      # payload.hermes.coding_delegate — who does the coding pass
# STARWEBHOOK_HERMES_BASE_URL=https://...  # optional echo for your Hermes / Metatron dashboard
# STARWEBHOOK_HERMES_INSTRUCTION=...       # optional static instruction string for the webhook consumer
# STARWEBHOOK_CODING_HANDOFF_ON_STAR=1     # optional: also flag coding_handoff on raw stars (default: only topic/list adds)
# TELEGRAM_BOT_TOKEN= TELEGRAM_CHAT_ID=   # optional Telegram notifications

# STARRED_STATE_FILE=data/github-starred-state.json   # optional override
#
# MCP (`gitgod serve`): scrape_web (Firecrawl), star_poll_*, exa_search / exa_contents / exa_answer (Exa), …
