# Copy to .env and fill in. Loaded automatically if you use python-dotenv in custom scripts;
# the stock agent reads OS env only — export these in your shell or use direnv.

# Optional: override paths to twint and tweets_analyzer (defaults: <repo>/.tmp/twitter-repos/...)
# TWINT_PATH=/path/to/twint
# TWEETS_ANALYZER_PATH=/path/to/tweets_analyzer

# Rate limits between fleet actions (seconds)
# RATE_JITTER_MIN=30
# RATE_JITTER_MAX=90

# XPOZ read-only social search (optional; see scripts/xpoz_spike.py and INTEGRATION.md)
# XPOZ_API_KEY=
# XPOZ_SERVER_URL=https://mcp.xpoz.ai/mcp
